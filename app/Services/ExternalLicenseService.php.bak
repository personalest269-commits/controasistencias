            ['LICENCIA_INSTALACION_ID', '', 'texto', 'ID estable de instalación', 'licencias'],
            ['LICENCIA_VALIDAR_CADA_MINUTOS', '60', 'numero', 'Intervalo entre validaciones automáticas', 'licencias'],
            ['LICENCIA_GRACIA_HORAS', '24', 'numero', 'Horas de gracia si el servidor no responde', 'licencias'],
            ['LICENCIA_TIMEOUT_SEGUNDOS', '10', 'numero', 'Timeout HTTP para validar licencia', 'licencias'],
            ['LICENCIA_BLOQUEAR_SIN_CONFIG', 'N', 'booleano', 'Bloquear el sistema si faltan datos de licencia', 'licencias'],
            ['LICENCIA_AUTO_ACTIVAR', 'S', 'booleano', 'Intentar activar la instalación automáticamente', 'licencias'],
            ['LICENCIA_BLOQUEO_HARDWARE', 'S', 'booleano', 'Amarrar licencia al hardware local', 'licencias'],
            ['LICENCIA_PROTEGER_CLONACION', 'S', 'booleano', 'Bloquear clonaciones si cambia la huella local', 'licencias'],
            ['LICENCIA_RSA_PUBLIC_KEY', '', 'texto', 'Llave pública RSA PEM para validar firmas del servidor', 'licencias'],
            ['LICENCIA_VERSION_ACTUAL', config('app.version', '1.0.0'), 'texto', 'Versión local instalada', 'licencias'],
            ['LICENCIA_UPDATE_AUTO_ACTIVO', 'N', 'booleano', 'Descargar automáticamente paquetes de actualización', 'licencias'],
            ['LICENCIA_UPDATE_AUTO_APLICAR', 'N', 'booleano', 'Aplicar automáticamente el paquete descargado', 'licencias'],
            ['LICENCIA_UPDATE_ENDPOINT', '/api/v1/licencias/updates/{license_key}', 'texto', 'Endpoint relativo para consultar actualizaciones', 'licencias'],
            ['LICENCIA_UPDATE_CHECK_MINUTOS', '180', 'numero', 'Intervalo para revisar actualizaciones', 'licencias'],
            ['LICENCIA_ULTIMA_VALIDACION_AT', '', 'texto', 'Última validación de licencia', 'licencias'],
            ['LICENCIA_ULTIMA_VALIDACION_OK', 'N', 'booleano', 'Último resultado de validación', 'licencias'],
            ['LICENCIA_ULTIMA_VALIDACION_OK_AT', '', 'texto', 'Fecha de última validación correcta', 'licencias'],
            ['LICENCIA_ULTIMO_ESTADO', '', 'texto', 'Último estado devuelto por el servidor', 'licencias'],
            ['LICENCIA_ULTIMO_MENSAJE', '', 'texto', 'Último mensaje de licencia', 'licencias'],
            ['LICENCIA_ULTIMA_RESPUESTA_CODIGO', '', 'texto', 'Último código HTTP recibido', 'licencias'],
            ['LICENCIA_FIRMA', '', 'texto', 'Última firma del servidor', 'licencias'],
            ['LICENCIA_RAW_RESPUESTA', '', 'texto', 'Última respuesta completa del servidor', 'licencias'],
            ['LICENCIA_ULTIMA_VALIDACION_OFFLINE_AT', '', 'texto', 'Última vez que se usó la caché offline', 'licencias'],
            ['LICENCIA_ACTIVADA', 'N', 'booleano', 'La instalación ya fue activada correctamente', 'licencias'],
            ['LICENCIA_HARDWARE_FINGERPRINT', '', 'texto', 'Huella actual del hardware', 'licencias'],
            ['LICENCIA_CLONE_FINGERPRINT', '', 'texto', 'Huella local anti clonación', 'licencias'],
            ['LICENCIA_UPDATE_ULTIMO_CHECK_AT', '', 'texto', 'Última consulta de actualizaciones', 'licencias'],
            ['LICENCIA_UPDATE_ULTIMO_ESTADO', '', 'texto', 'Último estado de actualización', 'licencias'],
            ['LICENCIA_UPDATE_ULTIMO_MENSAJE', '', 'texto', 'Último mensaje de actualización', 'licencias'],
            ['LICENCIA_UPDATE_ULTIMA_VERSION', '', 'texto', 'Última versión remota detectada', 'licencias'],
            ['LICENCIA_UPDATE_DOWNLOAD_URL', '', 'texto', 'URL de descarga del update detectado', 'licencias'],
            ['LICENCIA_UPDATE_CHECKSUM', '', 'texto', 'Checksum sha256 del update remoto', 'licencias'],
            ['LICENCIA_UPDATE_PAQUETE_LOCAL', '', 'texto', 'Ruta local del último paquete descargado', 'licencias'],
            ['LICENCIA_UPDATE_PAQUETE_NOMBRE', '', 'texto', 'Nombre del último paquete descargado', 'licencias'],
            ['LICENCIA_UPDATE_READY', 'N', 'booleano', 'Existe un paquete listo para aplicar', 'licencias'],
            ['LICENCIA_UPDATE_ULTIMA_APLICACION_AT', '', 'texto', 'Fecha de la última aplicación de update', 'licencias'],
            ['LICENCIA_UPDATE_ULTIMA_APLICACION_ESTADO', '', 'texto', 'Resultado de la última aplicación de update', 'licencias'],
            ['LICENCIA_UPDATE_ULTIMO_BACKUP', '', 'texto', 'Ruta del último backup previo a aplicar update', 'licencias'],
        ];

        foreach ($rows as [$k, $v, $t, $d, $g]) {
            PgConfiguracion::setValor($k, PgConfiguracion::valor($k, $v), $t, $d, $g);
        }

        if (trim((string) PgConfiguracion::valor('LICENCIA_INSTALACION_ID', '')) === '') {
            PgConfiguracion::setValor('LICENCIA_INSTALACION_ID', $this->suggestInstallationId(), 'texto', 'ID estable de instalación', 'licencias');
        }
        if (trim((string) PgConfiguracion::valor('LICENCIA_DOMINIO', '')) === '') {
            PgConfiguracion::setValor('LICENCIA_DOMINIO', $this->guessDomain(), 'texto', 'Dominio reportado al servidor de licencias', 'licencias');
        }
    }

