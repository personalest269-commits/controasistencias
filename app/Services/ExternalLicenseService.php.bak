class ExternalLicenseService
{
    private const CACHE_FILE = 'license/license_state.json';
    private const UPDATE_DIR = 'license_updates';

    public function defaults(): array
    {
        return [
            'server_url' => trim((string) PgConfiguracion::valor('LICENCIA_SERVIDOR_URL', '')),
            'license_key' => trim((string) PgConfiguracion::valor('LICENCIA_CLAVE', '')),
            'product_code' => trim((string) PgConfiguracion::valor('LICENCIA_PRODUCTO_CODIGO', '')),
            'domain' => trim((string) PgConfiguracion::valor('LICENCIA_DOMINIO', '')),
            'installation_id' => trim((string) PgConfiguracion::valor('LICENCIA_INSTALACION_ID', '')),
            'validate_minutes' => max(1, (int) PgConfiguracion::valor('LICENCIA_VALIDAR_CADA_MINUTOS', '60')),
            'grace_hours' => max(0, (int) PgConfiguracion::valor('LICENCIA_GRACIA_HORAS', '24')),
            'timeout_seconds' => max(3, (int) PgConfiguracion::valor('LICENCIA_TIMEOUT_SEGUNDOS', '10')),
            'block_without_config' => PgConfiguracion::bool('LICENCIA_BLOQUEAR_SIN_CONFIG', false),
            'auto_activate' => PgConfiguracion::bool('LICENCIA_AUTO_ACTIVAR', true),
            'clone_protection' => PgConfiguracion::bool('LICENCIA_PROTEGER_CLONACION', true),
            'hardware_lock' => PgConfiguracion::bool('LICENCIA_BLOQUEO_HARDWARE', true),
            'rsa_public_key' => trim((string) PgConfiguracion::valor('LICENCIA_RSA_PUBLIC_KEY', '')),
            'update_auto' => PgConfiguracion::bool('LICENCIA_UPDATE_AUTO_ACTIVO', false),
            'update_auto_apply' => PgConfiguracion::bool('LICENCIA_UPDATE_AUTO_APLICAR', false),
            'update_endpoint' => trim((string) PgConfiguracion::valor('LICENCIA_UPDATE_ENDPOINT', '/api/v1/licencias/updates/{license_key}')),
            'current_version' => trim((string) PgConfiguracion::valor('LICENCIA_VERSION_ACTUAL', config('app.version', '1.0.0'))),
            'update_check_minutes' => max(5, (int) PgConfiguracion::valor('LICENCIA_UPDATE_CHECK_MINUTOS', '180')),
        ];
    }

